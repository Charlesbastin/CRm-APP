# ============================================================
# TechnoCraft 2026 — Cloud Functions Environment Variables
#
# RAZORPAY KEY ID (non-secret, safe to store here)
# Get this from: https://dashboard.razorpay.com → API Keys
#
# IMPORTANT: NEVER put the Key Secret here.
# Store the Key Secret in Firebase Secret Manager:
#   firebase functions:secrets:set RAZORPAY_KEY_SECRET
# ============================================================

RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY_ID
